<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="invoice_comparison_wizard_form" model="ir.ui.view">
        <field name="name">invoice.comparison.wizard.form</field>
        <field name="model">invoice.comparison.wizard</field>
        <field name="arch" type="xml">
            <form string="Invoice Comparison Report">
                <group>
                    <field name="report_type"/>
                    <field name="years_count"/>
                    <field name="company_ids" widget="many2many_tags"/>
                    <field name="month" invisible="report_type != 'monthly'" required="report_type == 'monthly'"/>
                </group>
                <footer>
                    <button name="action_download_excel" string="Download Excel" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_invoice_comparison_wizard" model="ir.actions.act_window">
        <field name="name">Invoice Comparison Report</field>
        <field name="res_model">invoice.comparison.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>