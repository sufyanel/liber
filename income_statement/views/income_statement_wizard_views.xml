<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_income_statement_wizard_form" model="ir.ui.view">
        <field name="name">income.statement.wizard.form</field>
        <field name="model">income.statement.wizard</field>
        <field name="arch" type="xml">
            <form string="Income Statement">
                <group>
                    <field name="company_ids" widget="many2many_tags"/>
                    <field name="report_mode"/>
<!--                    <field name="year"/>-->
                </group>
                <footer>
                    <button name="action_download_excel" string="Download Excel" type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_income_statement_wizard" model="ir.actions.act_window">
        <field name="name">Income Statement</field>
        <field name="res_model">income.statement.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo>
