<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="income_statement_budget_company_rule" model="ir.rule">
        <field name="name">Income statement budget: company</field>
        <field name="model_id" ref="model_income_statement_budget"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>
    <record id="income_statement_budget_line_company_rule" model="ir.rule">
        <field name="name">Income statement budget line: company</field>
        <field name="model_id" ref="model_income_statement_budget_line"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>
    <record id="income_statement_account_mapping_company_rule" model="ir.rule">
        <field name="name">Income statement account mapping: company</field>
        <field name="model_id" ref="model_income_statement_account_mapping"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
    </record>
</odoo>
