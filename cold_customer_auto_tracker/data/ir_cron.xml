<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- System Parameters -->
        <record id="cold_customer_start_date_param" model="ir.config_parameter">
            <field name="key">cold_customer_start_date</field>
            <field name="value">2024-01-01</field>
        </record>

        <record id="cold_customer_end_date_param" model="ir.config_parameter">
            <field name="key">cold_customer_end_date</field>
            <field name="value">2024-12-31</field>
        </record>

        <!-- Cron Job -->
        <record id="ir_cron_mark_cold_customers" model="ir.cron">
            <field name="name">Mark Cold Customers</field>
            <field name="model_id" ref="base.model_res_partner"/>
            <field name="state">code</field>
            <field name="code">model._cron_mark_cold_customers()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="active">True</field>
        </record>
    </data>
</odoo>
