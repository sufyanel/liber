<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="threshold_report_wizard_form" model="ir.ui.view">
        <field name="name">threshold.report.wizard.form</field>
        <field name="model">threshold.report.wizard</field>
        <field name="arch" type="xml">
            <form string="Threshold Report">
                <group>
                    <group string="Companies &amp; Period">
                        <field name="company_ids" widget="many2many_tags"/>
                        <field name="duration" required="1"/>
                        <field name="year" invisible="duration == False" required="duration != False"/>
                        <field name="quarter" invisible="duration != 'quarter'" required="duration == 'quarter'"/>
                        <field name="month" invisible="duration != 'month'" required="duration == 'month'"/>
                    </group>
                    <group string="Manual Values">
                        <field name="capital_investments"/>
                        <field name="savings"/>
                        <field name="investor_return"/>
                        <field name="tax"/>
                    </group>
                </group>
                <footer>
                    <button name="action_download_excel" string="Download Excel Report" 
                            type="object" class="btn-primary"/>
                    <button string="Cancel" class="btn-secondary" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="threshold_report_wizard_action" model="ir.actions.act_window">
        <field name="name">Threshold Report</field>
        <field name="res_model">threshold.report.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="view_id" ref="threshold_report_wizard_form"/>
    </record>
</odoo>